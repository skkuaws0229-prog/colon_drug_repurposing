/*
 * Feature Engineering Pipeline Configuration
 * Project: 20260408_pre_project_biso_myprotocol
 */

params {
    // ── S3 Data Paths ──
    s3_base       = "s3://say2-4team/20260408_new_pre_project_biso/20260408_pre_project_biso_myprotocol"
    data_dir      = "${params.s3_base}/data"
    fe_output_dir = "${params.s3_base}/fe_output"
    run_id        = "20260408_fe_v1"

    // Input data URIs
    gdsc_ic50_uri          = "${params.data_dir}/gdsc_ic50.parquet"
    lincs_mcf7_uri         = "${params.data_dir}/lincs_mcf7.parquet"
    lincs_drug_sig_uri     = "${params.data_dir}/lincs_drug_signature_normalized.parquet"
    depmap_crispr_long_uri = "${params.data_dir}/depmap/depmap_crispr_long_20260408.parquet"
    drug_features_uri      = "${params.data_dir}/drug_features_catalog.parquet"

    gdsc_annotation_uri    = "${params.data_dir}/gsdc/gdsc2_drug_annotation_master_20260406.parquet"
    chembl_uri             = "${params.data_dir}/chembl/chembl_compound_master_basic_20260406.parquet"
    drugbank_uri           = "${params.data_dir}/drugbank/drugbank_drug_master_basic_20260406.parquet"
    drugbank_synonym_uri   = "${params.data_dir}/drugbank/drugbank_synonym_table_basic_20260406.parquet"
    metabric_expr_uri      = "${params.data_dir}/metabric/metabric_expression_basic_clean_20260406.parquet"
    msigdb_membership_uri  = "${params.data_dir}/msigdb/msigdb_gene_set_membership_basic_20260406.parquet"
    string_links_uri       = "${params.data_dir}/string/string_links_basic_20260406.parquet"
    opentargets_uri        = "${params.data_dir}/opentargets/opentargets_association_overall_direct_basic_20260406.parquet"
    drug_target_uri        = "${params.data_dir}/drug_target_mapping.parquet"

    // FE parameters
    binary_quantile = 0.3
}

// ── Process defaults ──
process {
    executor = 'local'
    memory   = '16 GB'
    cpus     = 4
    time     = '2h'

    errorStrategy = 'retry'
    maxRetries    = 1

    withName: 'prepare_fe_inputs' {
        memory = '16 GB'
        cpus   = 4
    }
    withName: 'build_features' {
        memory = '16 GB'
        cpus   = 4
    }
    withName: 'build_pair_features' {
        memory = '32 GB'
        cpus   = 8
        time   = '4h'
    }
    withName: 'upload_results' {
        memory = '4 GB'
        cpus   = 2
        time   = '1h'
    }
}

// ── Profiles ──
profiles {
    local {
        process.executor = 'local'
        docker.enabled   = true
    }

    awsbatch {
        process {
            executor       = 'awsbatch'
            queue          = 'team4-fe-queue-cpu'
            container      = '666803869796.dkr.ecr.ap-northeast-2.amazonaws.com/fe-v2-nextflow:v2-pip-awscli'
        }
        aws {
            region = 'ap-northeast-2'
            batch {
                volumes     = '/tmp'
            }
        }
        docker.enabled = false
    }
}

// ── Reports ──
report {
    enabled   = true
    file      = "${params.fe_output_dir}/reports/fe_report_${params.run_id}.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.fe_output_dir}/reports/fe_timeline_${params.run_id}.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.fe_output_dir}/reports/fe_trace_${params.run_id}.txt"
    overwrite = true
}

manifest {
    name            = 'drug-discovery-fe-pipeline'
    description     = 'Feature Engineering pipeline for drug response prediction'
    version         = '1.0.0'
    defaultBranch   = 'main'
}
